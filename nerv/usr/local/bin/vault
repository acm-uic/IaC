#!/usr/bin/env sh

# This script sets up some environment vars for the vault binary
# This is the most consistent way to ensure vault is always invoked
# with said env vars. 

set -eu

token_file="/etc/vault-agent/vault-token" # See vault-agent.service

if test -f "${token_file}"; then
    # This has to be double quotes!!!
    export VAULT_TOKEN="$(cat ${token_file})"
fi

export VAULT_SKIP_VERIFY="true"
export VAULT_ADDR="https://vault.acmuic.org"
exec _vault "$@"
